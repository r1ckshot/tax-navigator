# Скопіюй у .env і заповни справжніми значеннями. .env у gitignore, ніколи не комітиться.

# Anthropic API ключ для запуску Claude Code всередині devcontainer
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres connection string (rules-as-data, профілі, waitlist)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/tax_navigator?sslmode=require

# Публічний URL застосунку (canonical, OG-теги, шаринг результату анкети)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log level (debug, info, warn, error)
LOG_LEVEL=info
